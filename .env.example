# Local app runtime
APP_PORT=8000
APP_IMAGE=statuspulse-app:local
DB_HOST=db
DB_PORT=5432
DB_NAME=statuspulse
DB_USER=statuspulse
DB_PASSWORD=statuspulse
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
RATE_LIMIT_REQUESTS=60
RATE_LIMIT_WINDOW_SECONDS=60

# Production images
APP_BLUE_IMAGE=ghcr.io/ManojSelf/statuspulse:latest
APP_GREEN_IMAGE=ghcr.io/ManojSelf/statuspulse:latest
ACTIVE_SLOT=blue
APP_UPSTREAM_HOST=app_blue

# Production domain and TLS
DOMAIN=ak-info.online
PUBLIC_BASE_URL=https://ak-info.online
PUBLIC_HEALTH_URL=https://ak-info.online/health
CADDY_EMAIL=admin@ak-info.online

# Monitoring
UPTIME_KUMA_PORT=3001
ALERT_WEBHOOK_URL=
EXPECTED_CONTAINERS=statuspulse-caddy statuspulse-db statuspulse-redis
DB_CONTAINER=statuspulse-db
REDIS_CONTAINER=statuspulse-redis
TLS_HOST=ak-info.online
TLS_PORT=443
TLS_WARN_DAYS=14
DISK_WARN_PCT=80
MEMORY_WARN_PCT=90
MONITOR_PATH=/
HTTP_TIMEOUT_SECONDS=10
WEBHOOK_TIMEOUT_SECONDS=10
TCP_TIMEOUT_SECONDS=3
LOG_FILE=/opt/statuspulse/logs/statuspulse-monitor.log

# Backups
BACKUP_DIR=/opt/statuspulse/backups
BACKUP_RETENTION_COUNT=7
S3_BACKUP_BUCKET=
S3_BACKUP_PREFIX=statuspulse

# AWS / Terraform metadata
AWS_REGION=us-east-1
AWS_ACCOUNT_ID=381492115031
AWS_INSTANCE_NAME=statuspulse
